#!/usr/bin/env bash
# Copy stdin (or arguments) to the local clipboard via OSC 52.
#
# Works over SSH without X11/Wayland forwarding. The terminal emulator must
# support OSC 52 (iTerm2, kitty, WezTerm, recent xterm, Alacritty with the
# option enabled). Inside tmux the sequence is wrapped in the DCS passthrough
# so tmux forwards it to the outer terminal.
#
# Usage:
#   echo hello | osc52-copy
#   osc52-copy "some text"

set -euo pipefail

if [[ $# -gt 0 ]]; then
  payload=$*
else
  payload=$(cat)
fi

# OSC sequences cannot contain newlines, so strip base64's line-wrapping.
b64=$(printf '%s' "$payload" | base64 | tr -d '\n')

# OSC 52 format: ESC ] 52 ; <selection> ; <base64> BEL
# 'c' targets the system clipboard
seq=$'\033]52;c;'$b64$'\a'

if [[ -n ${TMUX:-} ]]; then
  # tmux's DCS passthrough requires every embedded ESC to be doubled,
  # then the whole payload wrapped in `ESC P tmux; ... ESC \` (ST).
  seq=${seq//$'\033'/$'\033\033'}
  seq=$'\033Ptmux;'$seq$'\033\\'
fi

# Write to the controlling tty so the sequence reaches the terminal even
# when stdout is piped/redirected. Fails loudly if no tty is available.
printf '%s' "$seq" >/dev/tty
